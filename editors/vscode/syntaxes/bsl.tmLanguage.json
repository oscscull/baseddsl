{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Based DSL",
  "scopeName": "source.bsl",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#raw" },
    { "include": "#decorators" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#params" },
    { "include": "#numbers" }
  ],
  "repository": {
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.bsl"
    },
    "strings": {
      "name": "string.quoted.double.bsl",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        { "match": "\\\\.", "name": "constant.character.escape.bsl" }
      ]
    },
    "raw": {
      "name": "string.quoted.other.raw.bsl",
      "begin": "`",
      "end": "`"
    },
    "decorators": {
      "match": "@[A-Za-z_][A-Za-z0-9_]*",
      "name": "entity.name.function.decorator.bsl"
    },
    "keywords": {
      "patterns": [
        {
          "match": "(->)\\s*(ok)\\b",
          "captures": {
            "2": { "name": "keyword.control.bsl" }
          }
        },
        {
          "match": "\\b(shape|scope|enum|query|mutation|filter)\\b",
          "name": "keyword.control.declaration.bsl"
        },
        {
          "match": "\\b(create|update|delete|restore|hard|tx|list|get|stream|from|where|order|page|offset|with|count|guard|scoped|unscoped|unindexed|unsafe|read|raw)\\b",
          "name": "keyword.control.bsl"
        },
        {
          "match": "\\b(and|or|not|in|has)\\b",
          "name": "keyword.operator.word.bsl"
        },
        {
          "match": "\\b(default|unique|column|now|asc|desc|max_rows|on|true|false|null)\\b",
          "name": "constant.language.bsl"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "match": "\\b(text|int|bool|timestamp|date|json|uuid|Id|float|decimal)\\b",
          "name": "support.type.primitive.bsl"
        },
        {
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b",
          "name": "entity.name.type.bsl"
        }
      ]
    },
    "params": {
      "match": "\\$[A-Za-z_][A-Za-z0-9_.]*",
      "name": "variable.parameter.bsl"
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.bsl"
    }
  }
}
