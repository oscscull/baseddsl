(* ============================================================================
   based DSL — canonical grammar
   ----------------------------------------------------------------------------
   Source of truth for what parses. Where the prose specs were ambiguous, this
   file commits; see decisions.md for the rationale of each commitment.

   Notation (ISO-ish EBNF):
     =            definition
     |            alternation
     { x }        zero or more x
     [ x ]        optional x
     ( x )        grouping
     'lit'        terminal literal
     (* ... *)    comment
   Layout is free (principle 3: no positional/whitespace meaning). Whitespace and
   comments separate tokens but never carry meaning. Items in a block are
   separated by NEWLINE or ',' — both accepted, neither significant.
   ============================================================================ *)

(* ---------- File ---------------------------------------------------------- *)
(* One extension (.bsl), one uniform grammar: any top-level declaration may     *)
(* appear in any file. Splitting schema vs access across files (model.bsl /     *)
(* queries.bsl) and grouping by domain dir is recommended convention, not       *)
(* enforced (decisions.md D6/D9).                                               *)

file        = { decl } ;
decl        = model | shape | scope_decl | enum_decl | query | mutation | named_filter ;
sep         = NEWLINE | ',' ;          (* item separator inside blocks/files   *)

(* ---------- Models -------------------------------------------------------- *)

model       = { model_deco } model_name '{' { member sep } [ member ] '}' ;
model_name  = upper_ident ;            (* UpperCamel; decl == ref, no fold (D7) *)

member      = field | index_decl | soft_override ;

(* A model header stacks decorators, one per line. `@scope Name` is a distinct    *)
(* form (D46): it references a top-level `scope` decl by name, no parenthesized    *)
(* predicate (the predicate lives in the `scope` decl — P4). Every other decorator *)
(* takes the generic parenthesized-args form. `@scope Name(field)` — a per-model   *)
(* scope-column override — is reserved but not yet accepted (D46).                 *)
(* Multi-scope (D47): `@scope` is REPEATABLE and its names are comma-separated.     *)
(* The stack is a disjunction of conjunctions (DNF): commas WITHIN one `@scope`     *)
(* are an AND-conjunction (one alternative — all named axes required together);     *)
(* the repeated decorators are OR-alternatives (each a valid confinement). So       *)
(* `@scope Page, Author` = one alternative {Page ∧ Author}; `@scope Page` +         *)
(* `@scope Author` on two lines = two alternatives {Page},{Author}. No new syntax:  *)
(* comma = AND, new line = OR.                                                      *)
model_deco  = scope_deco | decorator ;
scope_deco  = '@scope' scope_name { ',' scope_name } ;  (* one alternative (AND); repeatable = OR *)

(* Decorators stack above the model, one per line; never positional on header.  *)
(* `@no_id("reason")` opts a genuinely keyless legacy table out of the `id`      *)
(* primary key; the reason string is MANDATORY (like `unscoped(...)`).           *)
decorator   = '@' deco_name [ '(' [ deco_args ] ')' ] ;
deco_name   = ident ;              (* soft_delete sort scope table was no_id …   *)
deco_args   = deco_arg { ',' deco_arg } ;
deco_arg    = sort_term | predicate | ident | path | literal ;

(* Field line: uniform for columns and relations — `name: Type (modifiers)` *)
field       = field_name ':' field_type [ inverse_ref ] [ modifiers ]
                                       [ relation_opts ] [ was_directive ]
                                       [ field_sort ] ;
field_name  = lower_ident ;

(* A model field may also carry an OPAQUE type: a DB type the engine does not model    *)
(* (PostGIS `geometry`, `tsvector`, `inet`, …). The literal string rides verbatim into  *)
(* the DDL and the neutral snapshot (diff = string compare), the value is opaque end to *)
(* end, and filtering/sorting/writing it is rejected (models.md, raw.md). Only a field  *)
(* position accepts it — a param annotation or a scope term does not.                   *)
field_type  = type_expr | raw_spec [ '?' ] ;

type_expr   = base_type { type_qualifier } ;
base_type   = primitive | model_ref ;
primitive   = 'text' | 'int' | 'bool' | 'timestamp' | 'date'
            | 'json' | 'uuid' | 'Id' | 'float' | decimal ;
(* Fixed base-10 numeric. Bare `decimal` = `decimal(38, 9)`; args are compile-time  *)
(* INT literals, sema validates `1 <= scale <= precision <= 38` (E0159). models.md.  *)
decimal     = 'decimal' [ '(' INT ',' INT ')' ] ;
model_ref   = upper_ident ;            (* relation; resolves to a model (D7)   *)
type_qualifier = '?'                   (* nullable / optional                  *)
            | '[]' ;                   (* to-many                              *)

(* Opt-in inverse: points at the forward edge it pairs with.  (Model.field)   *)
inverse_ref = '(' model_ref '.' field_name ')' ;

(* Behavioral modifiers in parens: (unique), (default "x"), (default now()),    *)
(* (column "legacy_name") — alias a field onto a legacy / reserved-word column. *)
modifiers   = '(' modifier { ',' modifier } ')' ;
modifier    = 'unique'
            | 'default' default_val
            | 'column' STRING ;        (* legacy/reserved column-name override  *)
default_val = literal | func_call
            | variant ;                (* a bare identifier: an enum default (enums.md) *)

(* Migration rename directive (migrations.md): declares this field's previous     *)
(* physical column name so the diff emits a clean `rename column` instead of the   *)
(* default drop+add. Sits after the modifiers, before any @sort. Model-level       *)
(* renames use the decorator form `@was("old_table")` (matches `decorator` above). *)
(* Renames are NEVER auto-guessed — no `@was` means drop+add (principle 2).         *)
was_directive = '@was' '(' STRING ')' ;

(* Relation options — custom join condition for legacy keys (relations.md).    *)
relation_opts = '(' 'on' ':' predicate ')' ;

(* Per-field sort override for a relation traversal (sorting.md).              *)
field_sort  = '@sort' '(' sort_term { ',' sort_term } ')' ;

(* Index declaration inside a model body. Two exotic tiers ride the same decl        *)
(* (indexing.md): `using <method>` names a non-default access method (gist/gin/brin/   *)
(* hash; MariaDB fulltext/spatial), checked per target in sema (E0272); `@index        *)
(* raw("…")` is the opaque long tail (expression indexes, opclasses, partial WHERE),   *)
(* whose body is everything after `ON <table>` and is diffed as a literal string.      *)
index_decl  = '@index' ( raw_spec
                       | ( column_name | '(' column_name { ',' column_name } ')' )
                         [ 'unique' ] [ 'using' method_name ] ) ;
column_name = lower_ident ;
method_name = lower_ident ;      (* closed set enforced in sema, not here *)

(* The opaque `raw(…)` body, in type and index position. One literal for every target,  *)
(* or a per-dialect map when the spelling differs; a target absent from the map is      *)
(* E0270. Distinct from the backtick `raw`…`` value/predicate form below — same         *)
(* keyword, different position (D96: `raw` is the one escape-hatch spelling; `sql` is   *)
(* never a keyword).                                                                    *)
raw_spec    = 'raw' '(' ( STRING | dialect_map ) ')' ;
dialect_map = '{' dialect_entry { ',' dialect_entry } '}' ;
dialect_entry = dialect_name ':' STRING ;
dialect_name  = 'mariadb' | 'postgres' | 'sqlite' ;

(* Per-operation soft-delete override (soft-delete.md): `restore: raw`...``    *)
soft_override = op_name ':' raw_sql ;
op_name     = 'restore' | 'delete' | 'read' ;

(* ---------- Shapes -------------------------------------------------------- *)

shape       = 'shape' shape_name 'from' model_ref shape_body ;
shape_name  = upper_ident | 'full' ;   (* `shape full` is the conventional view*)
shape_body  = '{' { shape_field sep } [ shape_field ] '}' ;
(* A nest is spelled inline (`field { … }`) or as a reference to a top-level shape *)
(* decl by name (`field -> UserRow`, D79) — `->` reads "connects to", as in a       *)
(* relation decl and a param binding. The referenced shape's `from` model must     *)
(* equal the relation's target; the reference is a pure body expansion (`full` is  *)
(* per-model, so it is never referenced this way).                                 *)
shape_field = bare_field                       (* local, same-name             *)
            | out_name '=' shape_value          (* reach-and-rename / raw / agg *)
            | bare_field shape_body             (* nest a relation into subobj  *)
            | bare_field '->' upper_ident ;     (* nest via a named shape (D79) *)
bare_field  = lower_ident ;
out_name    = lower_ident ;
shape_value = path | raw_sql | aggregate ;     (* dotted traversal, raw, or agg *)

(* An aggregate over the shape's grouped rows (queries.md group by / having). A shape *)
(* carrying any of these is an *aggregate shape*: a projection over groups, not rows.  *)
(* `count` is arg-less (rows in the group); the others take one column. The function   *)
(* name set is closed in sema. Result types: count -> int (non-null); sum -> the        *)
(* column's numeric type; avg -> float; min/max -> the column's type; all but count      *)
(* nullable.                                                                             *)
aggregate   = agg_func '(' [ path ] ')' ;
agg_func    = 'count' | 'sum' | 'avg' | 'min' | 'max' ;   (* contextual, checked in sema *)

(* ---------- Scopes (auth.md Handle 2, D46) -------------------------------- *)
(* A named row-visibility contract, declared once and referenced by name on the     *)
(* model it governs (`@scope Name`) and every callable that touches it (`scoped      *)
(* Name`). The predicate is the D32 restricted form — a conjunction of `col =        *)
(* $ctx.field` equalities — with the column's (and thus $ctx field's) type declared  *)
(* here (D46), which sources the scope field's type instead of D4/D5 inference.      *)

scope_decl  = 'scope' scope_name '(' scope_term { ',' scope_term } ')' ;
scope_name  = upper_ident ;            (* UpperCamel; decl == ref, no fold (D7) *)
scope_term  = column_name ':' type_expr '=' param_ref ;   (* col: Type = $ctx.field *)

(* ---------- Enums (enums.md) ---------------------------------------------- *)
(* A closed set of lowercase variants and a first-class scalar type. The name shares  *)
(* the type-name namespace with models/shapes/scopes (dup = E0106). A field typed by   *)
(* an enum name is a scalar column, not a relation — sema disambiguates by what the     *)
(* UpperCamel name resolves to. A variant appears in value position as a bare           *)
(* identifier (an ordinary single-segment path), resolved against the column's enum.    *)

enum_decl   = 'enum' enum_name '{' { variant sep } [ variant ] '}' ;
enum_name   = upper_ident ;            (* UpperCamel; decl == ref, no fold (D7) *)
(* A variant is a bare name, optionally with an explicit wire value. The name is always  *)
(* the identifier (client variant, go-to-def, rename); the value is what the wire + DB    *)
(* store. Kind is inferred in sema: no int value anywhere => a string enum (bare name or   *)
(* explicit string, name may differ from value); an int value on EVERY variant => an int   *)
(* enum. Mixing the two, a duplicate value, or an int-alongside-bare/string is a sema error*)
(* (enums.md). Value position always references a variant by NAME (a bare single-segment   *)
(* path), never by its raw value.                                                          *)
variant     = lower_ident [ '=' ( STRING | INT ) ] ;

(* ---------- Queries ------------------------------------------------------- *)

query       = 'query' query_name '(' [ params ] ')' '->' ret_type
              [ scope_ack ] ( query_inline | query_block | ';' ) ;
query_name  = lower_ident ;

(* Per-callable scope acknowledgement (auth.md Handle 2 / D32 / D46 / D47). A callable *)
(* whose target model is in a scope MUST carry exactly one of these (else E0182):     *)
(*  - `scoped Name[, Name]*` accepts standing scope(s). The named axis set must be a   *)
(*    SUPERSET of ≥1 declared `@scope` alternative for EACH scoped model it touches     *)
(*    (root + joined reaches, D34) — too few axes to satisfy any alternative, or an     *)
(*    axis no touched model declares, is E0185 (D47). An AND model needs both axes; an  *)
(*    OR model is satisfied by either.                                                  *)
(*  - `unscoped("reason")` opts the one callable out of ALL scope handling (cross-scope *)
(*    admin/support/jobs). Mandatory reason — an escape hatch is never silent (P6);    *)
(*    greppable + linted (W0106). The two are mutually exclusive.                       *)
(* Sits after the return type on a query, after any `guard` on a mutation.            *)
scope_ack       = scoped_clause | unscoped_clause ;
scoped_clause   = 'scoped' scope_name { ',' scope_name } ;   (* mirrors `guard name` *)
unscoped_clause = 'unscoped' '(' STRING ')' ;

(* Bare/per-param/full all share the param list; binding rides each param.     *)
params      = param { ',' param } ;
param       = param_name [ ':' type_expr ] [ param_binding ] [ '=' default_val ] ;
param_name  = lower_ident ;
(* binding forms: (queries.md)
     (id)                         same-name equality, type inferred
     (user: User)                 typed, same-name equality
     (user -> author)             bind via named relation/edge
     (since: timestamp > created_at)  explicit column + operator               *)
param_binding = '->' field_name                          (* bind via edge      *)
            | op column_name ;                           (* explicit col + op  *)

(* `stream X` = the incremental many-contract (streaming.md): NDJSON wire body +  *)
(* Stream-returning client method. `stream` already means many, so no `[]` after  *)
(* the shape. Query-only (a mutation return never streams, E0202); body verb must *)
(* be `list` (E0200); `page` is forbidden on a stream query (E0201).              *)
(* `ok` = the shapeless acknowledgement of a destructive mutation (mutations.md): *)
(* a real DELETE leaves no surviving row, so there is no shape to read back.      *)
(* Mutation-only (a query returns data, E0222) and only where every write is a    *)
(* real DELETE (E0221); a real-DELETE mutation may not declare a shape (E0220).   *)
ret_type    = 'ok' | 'stream' type_ref | type_ref [ '[]' ] ;
type_ref    = shape_name | model_ref ;  (* a shape or a model's `full`         *)

(* Inline tail clauses allowed on an otherwise-bare query (e.g. `order (...)`). *)
query_inline = clause { clause } ';' ;

(* A query block holds one engine-built read statement, or — the whole-query raw
   level (raw.md) — one `raw` backtick block that IS the statement. A raw body's
   params must carry explicit types and no binding; `${param}` stays a bound
   parameter and the declared shape types the result columns (sema E021x).       *)
query_block = '{' ( statement | raw_body ) '}' ;
raw_body    = raw_sql ';' ;

(* ---------- Mutations ----------------------------------------------------- *)

mutation    = 'mutation' query_name '(' [ params ] ')' '->' ret_type
              [ 'guard' guard_name ] [ scope_ack ] mut_block ;
guard_name  = lower_ident ;             (* host-language fn (auth.md Handle 3)  *)
mut_block   = '{' { write_stmt sep } [ write_stmt ] '}' ;

write_stmt  = create_stmt | update_stmt | delete_stmt
            | restore_stmt | hard_delete_stmt | tx_block | raw_sql ;

(* A create may name a conflict target (a unique key) + an `update` branch — upsert       *)
(* (mutations.md). On a unique collision the `update` runs over the existing row (the      *)
(* same self-referential arithmetic an ordinary `update` allows) instead of inserting;     *)
(* the winning row reads back keyed on the conflict target. Postgres/SQLite lower to        *)
(* `ON CONFLICT (cols) DO UPDATE`, MariaDB to `ON DUPLICATE KEY UPDATE`. Sema E0250-E0254.  *)
create_stmt = 'create' model_ref assign_block [ on_conflict ] ;
on_conflict = 'on' 'conflict' '(' column_name { ',' column_name } ')' 'update' assign_block ;
update_stmt = 'update' model_ref where_clause assign_block ;
delete_stmt = 'delete' model_ref where_clause ;
restore_stmt= 'restore' model_ref where_clause ;
hard_delete_stmt = 'hard' 'delete' model_ref where_clause ;

assign_block = '{' { assign sep } [ assign ] '}' ;
assign      = column_name '=' assign_rhs ;

(* An update assignment's RHS is a scalar arithmetic expression over the target      *)
(* model's own numeric columns, params, and numeric literals (mutations.md) — lowered *)
(* to a real SQL `SET col = <expr>`, never read-modify-write. A bare `value` is the    *)
(* common (and, for `create`, the only — E0230) case. `*` `/` bind tighter than        *)
(* `+` `-`; left-associative; parenthesize to override. Numeric family only (E0231).   *)
assign_rhs   = arith_expr ;
arith_expr   = arith_term { ( '+' | '-' ) arith_term } ;
arith_term   = arith_factor { ( '*' | '/' ) arith_factor } ;
arith_factor = value | '(' arith_expr ')' ;

(* Atomic group; back-reference a prior step's row with `^`.                   *)
tx_block    = 'tx' '{' { write_stmt sep } [ write_stmt ] '}' ;

(* ---------- Read statement (query block body) ----------------------------- *)

statement   = verb model_ref { clause } ';' ;
verb        = 'get' | 'list' ;          (* signature [] vs scalar still drives  *)
                                        (* the client contract independently   *)
clause      = where_clause | order_clause | page_clause | unindexed_clause
            | group_clause | having_clause ;
where_clause= 'where' '(' predicate ')' ;
order_clause= 'order' '(' sort_term { ',' sort_term } ')' ;
sort_term   = path [ 'asc' | 'desc' ] ;

(* Aggregation (queries.md): legal only on an aggregate-shape query. `group by` lists      *)
(* the grouping columns; every non-aggregate projected column must appear here (E0242).    *)
(* `having` filters groups by their aggregates — same predicate language as `where`, but    *)
(* its left operands name the shape's projected aggregate aliases / group columns. Both     *)
(* are E0243 on a non-aggregate query; `page` on an aggregate query is E0244.               *)
group_clause = 'group' 'by' '(' path { ',' path } ')' ;
having_clause= 'having' '(' predicate ')' ;

(* Pagination (pagination.md): keyset default; offset / count are loud opt-ins.*)
page_clause = 'page' '(' INT ')' [ 'offset' ] [ 'with' 'count' ] ;

(* Missing-index annotation (indexing.md): the query is knowingly unindexed.    *)
(* `max_rows` is a checked assertion; `unsafe` is the loud, greppable opt-out.  *)
unindexed_clause = 'unindexed' '(' ( 'max_rows' ':' INT
                                   | 'unsafe' [ ',' STRING ] ) ')' ;

(* ---------- Named filters (queries.md) ------------------------------------ *)

named_filter= 'filter' filter_name [ '(' params ')' ] '=' predicate ';' ;
filter_name = lower_ident ;

(* ---------- Predicate language (shared: where / scope / filter / guard) ---- *)
(* One expression language everywhere. `and` binds tighter than `or`;          *)
(* `not` is unary and binds tightest. No other precedence (queries.md).        *)

predicate   = or_expr ;
or_expr     = and_expr { 'or' and_expr } ;
and_expr    = not_expr { 'and' not_expr } ;
not_expr    = [ 'not' ] atom ;
atom        = '(' predicate ')'
            | comparison
            | path                      (* bool column used directly: `active` *)
            | filter_call               (* reuse a named filter                *)
            | raw_sql ;                  (* raw predicate term (raw.md)          *)
(* `in` takes either a single bare value (`col in $param` — one bound value) or a *)
(* parenthesized value list (`status in (open, waiting, $other)`) — elements are   *)
(* literals, enum variants, `$param` refs, or columns, each checked against the    *)
(* left column's type (queries.md).                                                *)
comparison  = path 'in' value_list
            | path op value ;
value_list  = '(' value { ',' value } ')' ;
filter_call = filter_name [ '(' [ value { ',' value } ] ')' ] ;

op          = '=' | '!=' | '>' | '<' | '>=' | '<='
            | '~'                       (* like                                 *)
            | 'in'
            | 'has' ;                   (* array/json containment               *)

(* ---------- Values, paths, literals --------------------------------------- *)

value       = param_ref | back_ref | path | literal | func_call ;
param_ref   = '$' param_name { '.' lower_ident } ;   (* $id, $ctx.org          *)
back_ref    = '^' '.' lower_ident ;                  (* tx back-ref: `^.id`     *)
path        = lower_ident { '.' lower_ident } ;       (* dotted traversal       *)

func_call   = func_name '(' [ value { ',' value } ] ')' ;
func_name   = 'now' | ident ;           (* closed set enforced in sema, not here*)

literal     = STRING | INT | FLOAT | 'true' | 'false' | 'null' ;
(* A FLOAT literal is carried as its exact source text (AST `Literal::Decimal`), so a  *)
(* `decimal` default / value is byte-exact — never rounded through an f64.             *)

(* ---------- Raw SQL escape hatch (raw.md) --------------------------------- *)
(* Backtick `raw` form. `${param}` interpolates as a bound parameter only.     *)
(* `{table}` / `{id}` are engine-provided safe interpolations in overrides.    *)

raw_sql     = 'raw' '`' { raw_char | interp } '`' ;
interp      = '${' param_ref '}' | '{' ident '}' ;
raw_char    = ? any char except '`' and an interp opener ? ;

(* ---------- Lexical ------------------------------------------------------- *)

(* Keywords are contextual (decisions.md D8): a word is a keyword only where the *)
(* grammar expects one; elsewhere it is an ordinary ident. A field may thus be   *)
(* named `order:` even though `order (...)` is a clause. Legacy keyword-named    *)
(* columns/tables may also be aliased via (column "...") / @table("...").        *)
(* Keyword-in-position set additionally includes `scope` (decl head + `@scope`)  *)
(* and `scoped` (the callable acknowledgement) — D46; both contextual. `enum`     *)
(* (decl head, enums.md) is likewise contextual, as are `stream` and `ok`          *)
(* (return-type position only; streaming.md / mutations.md).                       *)
ident       = lower_ident | upper_ident ;
lower_ident = lower_alpha { alnum | '_' } ;
upper_ident = upper_alpha { alnum } ;   (* UpperCamel model references         *)
alnum       = letter | digit ;
lower_alpha = 'a'..'z' | '_' ;
upper_alpha = 'A'..'Z' ;
letter      = 'a'..'z' | 'A'..'Z' ;
digit       = '0'..'9' ;

INT         = digit { digit } ;
FLOAT       = digit { digit } '.' digit { digit } ;
STRING      = '"' { ? any char except '"' or escaped ? } '"' ;
NEWLINE     = ? U+000A, optionally preceded by U+000D ? ;
COMMENT     = '#' { ? any char except NEWLINE ? } ;   (* line comment, ignored  *)
